# Firebase web config — from the rental-tracker-app-2026 project
# (Project settings > General > Your apps > SDK setup and configuration).
# projectId/authDomain/storageBucket follow the project id; apiKey,
# messagingSenderId and appId are unique to the project — paste them in.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=rental-tracker-app-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=rental-tracker-app-2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=rental-tracker-app-2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""
FIREBASE_DATABASE_URL=
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
SENDGRID_API_KEY=SG.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Gemini (AI chat assistant)
GEMINI_API_KEY=

# GoHighLevel CRM (Private Integration Token + location id)
