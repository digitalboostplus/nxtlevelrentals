rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Cross-service read of the caller's Firestore role.
    function callerRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && callerRole() in ['admin', 'super-admin'];
    }

    function isSuperAdmin() {
      return request.auth != null && callerRole() == 'super-admin';
    }

    // Profile images - users manage their own; super-admins manage all
    match /users/{userId}/profile/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || isSuperAdmin()
      );
    }

    // Property images - admins can upload, any signed-in user can read
    match /properties/{propertyId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Maintenance request attachments - the owning tenant or an admin
    match /maintenanceRequests/{requestId}/{allPaths=**} {
      allow read: if request.auth != null && (
        resource.metadata.tenantId == request.auth.uid || isAdmin()
      );
      allow write: if request.auth != null && (
        request.resource.metadata.tenantId == request.auth.uid || isAdmin()
      );
    }

    // Lease documents - admins upload, tenants read their own
    match /leaseDocuments/{documentId}/{allPaths=**} {
      allow read: if request.auth != null && (
        resource.metadata.tenantId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }
  }
}
